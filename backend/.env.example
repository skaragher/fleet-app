NODE_ENV=development
PORT=3000
JWT_SECRET=change_me

# Exemple Postgres (adapte selon ton environnement)
DATABASE_URL=postgresql://user:password@localhost:5432/fleet_db

# Base URL du frontend (utilisé pour générer le lien de reset)
APP_BASE_URL=http://localhost:5173

# Réinitialisation mot de passe
PASSWORD_RESET_TOKEN_SECRET=change_me_too
PASSWORD_RESET_EXPIRES_MINUTES=30
PASSWORD_RESET_DEBUG=true

# SMTP (optionnel). Si non configuré, le backend n'enverra pas d'email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Exemples:
# Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tonadresse@gmail.com
# SMTP_PASS=mot_de_passe_application
# SMTP_FROM=tonadresse@gmail.com
#
# Outlook / Office365:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
